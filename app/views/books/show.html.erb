<% content_for :title, @book.title %>

<div class="container">
  <% if notice %>
    <div class="notice"><%= notice %></div>
  <% end %>

  <%= render @book %>

  <div class="show-actions">
    <%= link_to "Edit", edit_book_path(@book), class: "btn" %>
    <%= link_to "Back", books_path, class: "btn btn-secondary" %>
    <%= button_to "Delete", book_path(@book), method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Are you sure you want to delete this book?" } %>
  </div>
</div>
