<% content_for :title, "Book Library" %>

<div class="container">
  <header>
    <h1>Book Library</h1>
    <p>Your personal collection of books</p>
  </header>

  <% if notice %>
    <div class="notice"><%= notice %></div>
  <% end %>

  <div style="margin-bottom: 1.5rem;">
    <%= link_to "Add New Book", new_book_path, class: "btn" %>
  </div>

  <% if @books.any? %>
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Author</th>
          <th>ISBN</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @books.each do |book| %>
          <tr>
            <td data-label="Title"><strong><%= book.title %></strong></td>
            <td data-label="Author"><%= book.author %></td>
            <td data-label="ISBN"><%= book.isbn.presence || "—" %></td>
            <td data-label="Status">
              <span class="badge badge-<%= book.status.parameterize %>">
                <%= book.status %>
              </span>
            </td>
            <td data-label="Actions">
              <div class="actions">
                <%= link_to book, title: "View", class: "icon-btn" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <% end %>
                <%= link_to edit_book_path(book), title: "Edit", class: "icon-btn" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                <% end %>
                <%= button_to book_path(book), method: :delete, class: "icon-btn delete-btn", title: "Delete", data: { turbo_confirm: "Are you sure you want to delete this book?" } do %>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <p>No books in your library yet.</p>
      <%= link_to "Add Your First Book", new_book_path, class: "btn" %>
    </div>
  <% end %>
</div>
